{
  "name": "react-spring-bottom-sheet-updated",
  "description": "✨ Accessible, 🪄 Delightful, and 🤯 Performant. Built on react-spring for the web, and @use-gesture/react.",
  "license": "MIT",
  "type": "module",
  "author": "wh1teee",
  "homepage": "https://github.com/wh1teee/react-spring-bottom-sheet-updated",
  "repository": "wh1teee/react-spring-bottom-sheet-updated",
  "bugs": {
    "url": "https://github.com/wh1teee/react-spring-bottom-sheet-updated/issues"
  },
  "version": "4.0.0-beta.10",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "files": [
    "defaults.json",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "next build",
    "prebuild:dist": "rimraf dist/**",
    "build:dist": "npm run build:postcss && npm run build:lib",
    "build:lib": "tsup",
    "build:postcss": "postcss -d dist src/style.css",
    "dev": "next dev",
    "turbo": "next dev --turbopack",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "prebuild": "npm run lint && npm run type-check",
    "prepublishOnly": "npm run build:dist",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "sideEffects": [
    "*.css"
  ],
  "types": "dist/index.d.ts",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/material-nextjs": "^7.2.0",
    "@radix-ui/react-portal": "^1.1.9",
    "@react-spring/web": "^10.0.1",
    "@use-gesture/react": "^10.3.1",
    "@xstate/react": "^5.0.5",
    "focus-trap": "^7.6.5",
    "svgo": "3.3.2",
    "xstate": "^5.20.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@jest/globals": "^30.0.4",
    "@rooks/use-raf": "^4.11.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.17.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@use-it/interval": "^1.0.0",
    "@xstate/inspect": "^0.8.0",
    "@xstate/test": "^0.5.1",
    "classnames": "^2.5.1",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.4.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.3.0",
    "husky": "^8.0.3",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^13.3.0",
    "tsup": "^8.3.5",
    "next": "^15.4.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-inline-svg": "^6.0.0",
    "postcss-preset-env": "^10.2.4",
    "prettier": "^3.6.2",
    "prettier-package-json": "^2.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^5.0.10",
    "semantic-release": "^21.1.2",
    "smooth-scroll-into-view-if-needed": "^2.0.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.38.0"
  },
  "keywords": [
    "animation",
    "bottom-drawer",
    "bottom-sheet",
    "bottomsheet",
    "dialog",
    "drag-drop",
    "draggableview",
    "drawer",
    "gesture-control",
    "modal",
    "motion",
    "overlay",
    "popup",
    "react",
    "react-spring",
    "@use-gesture/react",
    "sheet",
    "typescript"
  ],
  "browserslist": [
    "> 0.5%",
    "not dead",
    "not op_mini all"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "jsnext:main": "dist/index.es.js",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,md,html,css,yml,json}": "prettier --write",
    "package.json": "prettier-package-json --write"
  },
  "meta": {
    "twitter:site": "@wh1teee",
    "twitter:image:src": "https://github.com/wh1teee/react-spring-bottom-sheet-updated/blob/main/public/somecard.png"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "source": "src/index.tsx",
  "style": "dist/style.css"
}
