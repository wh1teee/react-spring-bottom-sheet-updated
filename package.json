{
  "name": "react-spring-bottom-sheet-updated",
  "description": "✨ Accessible, 🪄 Delightful, and 🤯 Performant. Built on react-spring for the web, and @use-gesture/react.",
  "license": "MIT",
  "type": "module",
  "author": "wh1teee",
  "homepage": "https://github.com/wh1teee/react-spring-bottom-sheet-updated",
  "repository": {
    "type": "git",
    "url": "https://github.com/wh1teee/react-spring-bottom-sheet-updated.git"
  },
  "bugs": {
    "url": "https://github.com/wh1teee/react-spring-bottom-sheet-updated/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/wh1teee"
  },
  "version": "4.0.0-beta.4",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css",
      "default": "./dist/style.css"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "defaults.json",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "next build",
    "build:lib": "tsup",
    "build:lib:watch": "tsup --watch",
    "build:css": "postcss -d dist src/style.css",
    "prebuild:lib": "rimraf dist/**",
    "build:dist": "pnpm run prebuild:lib && pnpm run build:lib && pnpm run build:css",
    "dev": "next dev",
    "dev:vite": "vite",
    "dev:lib": "pnpm run build:lib:watch",
    "turbo": "next dev --turbopack",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "type-check:lib": "tsc --project tsconfig.lib.json --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prebuild": "pnpm run lint && pnpm run type-check",
    "prepublishOnly": "pnpm run build:dist && pnpm run test:run",
    "postpublish": "echo 'Package published successfully!'",
    "start": "next start",
    "analyze": "pnpm run build:lib && npx webpack-bundle-analyzer dist/index.js",
    "clean": "rimraf dist dist-demo coverage .next"
  },
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@radix-ui/react-portal": "^1.1.9",
    "@react-spring/web": "^10.0.1",
    "@use-gesture/react": "^10.3.1",
    "@xstate/react": "^5.0.5",
    "focus-trap": "^7.6.5",
    "svgo": "3.3.2",
    "xstate": "^5.19.4"
  },
  "peerDependencies": {
    "react": "^16.14.0 || 17 || 18 || 19"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@babel/core": "^7.27.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@rooks/use-raf": "^4.11.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@use-it/interval": "^1.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vitejs/plugin-react-swc": "^3.10.1",
    "@xstate/inspect": "^0.8.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "classnames": "^2.5.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.2.0",
    "husky": "^8.0.3",
    "jsdom": "^25.0.1",
    "lint-staged": "^13.3.0",
    "next": "^15.3.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-custom-properties-fallback": "^1.0.2",
    "postcss-inline-svg": "^6.0.0",
    "postcss-preset-env": "^10.2.3",
    "prettier": "^3.5.3",
    "prettier-package-json": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^5.0.10",
    "semantic-release": "^21.1.2",
    "smooth-scroll-into-view-if-needed": "^2.0.2",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "animation",
    "bottom-drawer",
    "bottom-sheet",
    "bottomsheet",
    "dialog",
    "drag-drop",
    "draggableview",
    "drawer",
    "gesture-control",
    "modal",
    "motion",
    "overlay",
    "popup",
    "react",
    "react-spring",
    "@use-gesture/react",
    "sheet",
    "typescript"
  ],
  "browserslist": [
    "Chrome >= 49",
    "Android >= 58",
    "Safari >= 9.1",
    "iOS >= 9.3",
    "Firefox >= 31",
    "Edge >= 16"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,md,html,css,yml,json}": "prettier --write",
    "package.json": "prettier-package-json --write"
  },
  "meta": {
    "twitter:site": "@wh1teee",
    "twitter:image:src": "https://github.com/wh1teee/react-spring-bottom-sheet-updated/blob/main/public/somecard.png"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "source": "src/index.tsx",
  "style": "dist/style.css"
}
